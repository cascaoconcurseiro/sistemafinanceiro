// Schema Otimizado para Sistema Financeiro Integrado
// Versão: 2.0 - Reconstrução Completa
// Objetivo: Única fonte de verdade com integridade total

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["relationJoins", "fullTextSearch"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================================
// CORE MODELS - Base do Sistema
// ============================================================================

model User {
  id              String            @id @default(cuid())
  email           String            @unique
  name            String
  password        String
  avatar          String?
  is_active       Boolean           @default(true)
  last_login      DateTime?
  monthly_income  Decimal?          @db.Decimal(15,2)
  emergency_reserve Decimal?        @db.Decimal(15,2)
  risk_profile    String?
  financial_goals String?
  preferences     Json?
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  
  // Relacionamentos
  accounts        Account[]
  transactions    Transaction[]
  goals           Goal[]
  investments     Investment[]
  trips           Trip[]
  budgets         Budget[]
  contacts        Contact[]
  shared_expenses SharedExpense[]
  audit_events    AuditEvent[]
  recurring_rules RecurringRule[]

  @@map("users")
}

model Account {
  id              String            @id @default(cuid())
  user_id         String
  name            String
  type            String            // checking, savings, credit_card, investment, cash
  subtype         String?           // conta_corrente, poupanca, cartao_credito, etc
  currency        String            @default("BRL")
  balance         Decimal           @default(0) @db.Decimal(15,2)
  credit_limit    Decimal?          @db.Decimal(15,2)
  description     String?
  bank_name       String?
  account_number  String?
  is_active       Boolean           @default(true)
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  
  // Relacionamentos
  user            User              @relation(fields: [user_id], references: [id], onDelete: Cascade)
  transactions    Transaction[]
  shared_expenses SharedExpense[]
  recurring_rules RecurringRule[]

  @@map("accounts")
}

model Category {
  id               String            @id @default(cuid())
  name             String
  type             String            // income, expense, transfer
  parent_id        String?
  color            String?           // Para UI
  icon             String?           // Para UI
  is_active        Boolean           @default(true)
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")
  
  // Relacionamentos
  parent           Category?         @relation("CategoryHierarchy", fields: [parent_id], references: [id])
  children         Category[]        @relation("CategoryHierarchy")
  transactions     Transaction[]
  budgets          Budget[]
  recurring_rules  RecurringRule[]

  @@map("categories")
}

// ============================================================================
// TRANSACTION SYSTEM - Sistema de Transações Unificado
// ============================================================================

model Transaction {
  id                      String        @id @default(cuid())
  user_id                 String
  account_id              String
  category_id             String
  type                    String        // income, expense, transfer
  amount                  Decimal       @db.Decimal(15,2)
  description             String
  date                    DateTime
  status                  String        @default("COMPLETED") // PENDING, COMPLETED, CANCELLED
  reference               String?       // Referência externa
  tags                    String[]      @default([])
  metadata                Json?
  
  // Para transferências
  to_account_id           String?
  transfer_fee            Decimal?      @db.Decimal(15,2)
  
  // Para parcelamentos
  installment_number      Int?
  total_installments      Int?
  parent_transaction_id   String?
  
  // Auditoria
  createdAt               DateTime      @default(now()) @map("created_at")
  updatedAt               DateTime      @updatedAt @map("updated_at")
  
  // Relacionamentos
  user                    User          @relation(fields: [user_id], references: [id], onDelete: Cascade)
  account                 Account       @relation(fields: [account_id], references: [id], onDelete: Cascade)
  category                Category      @relation(fields: [category_id], references: [id])
  to_account              Account?      @relation("TransferToAccount", fields: [to_account_id], references: [id])
  parent_transaction      Transaction?  @relation("TransactionInstallments", fields: [parent_transaction_id], references: [id])
  installments            Transaction[] @relation("TransactionInstallments")
  shared_expenses         SharedExpense[]

  @@map("transactions")
}

model SharedExpense {
  id              String      @id @default(cuid())
  transaction_id  String
  user_id         String
  account_id      String
  share_amount    Decimal     @db.Decimal(15,2)
  share_percentage Decimal?   @db.Decimal(5,2)
  status          String      @default("PENDING") // PENDING, PAID, CANCELLED
  paid_date       DateTime?
  notes           String?
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  
  // Relacionamentos
  transaction     Transaction @relation(fields: [transaction_id], references: [id], onDelete: Cascade)
  user            User        @relation(fields: [user_id], references: [id], onDelete: Cascade)
  account         Account     @relation(fields: [account_id], references: [id], onDelete: Cascade)

  @@map("shared_expenses")
}

// ============================================================================
// INVESTMENT SYSTEM - Sistema de Investimentos
// ============================================================================

model Investment {
  id              String      @id @default(cuid())
  user_id         String
  name            String
  type            String      // stock, bond, fund, crypto, real_estate
  symbol          String?     // Ticker symbol
  broker          String?
  quantity        Decimal     @db.Decimal(15,8)
  purchase_price  Decimal     @db.Decimal(15,2)
  current_price   Decimal?    @db.Decimal(15,2)
  purchase_date   DateTime
  maturity_date   DateTime?
  fees            Decimal     @default(0) @db.Decimal(15,2)
  status          String      @default("ACTIVE") // ACTIVE, SOLD, MATURED
  metadata        Json?
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  
  // Relacionamentos
  user            User        @relation(fields: [user_id], references: [id], onDelete: Cascade)
  dividends       Dividend[]

  @@map("investments")
}

model Dividend {
  id              String      @id @default(cuid())
  investment_id   String
  amount          Decimal     @db.Decimal(15,2)
  payment_date    DateTime
  type            String      // dividend, interest, capital_gain
  tax_withheld    Decimal?    @db.Decimal(15,2)
  createdAt       DateTime    @default(now()) @map("created_at")
  
  // Relacionamentos
  investment      Investment  @relation(fields: [investment_id], references: [id], onDelete: Cascade)

  @@map("dividends")
}

// ============================================================================
// GOALS & BUDGETS - Metas e Orçamentos
// ============================================================================

model Goal {
  id              String      @id @default(cuid())
  user_id         String
  name            String
  description     String?
  target_amount   Decimal     @db.Decimal(15,2)
  current_amount  Decimal     @default(0) @db.Decimal(15,2)
  target_date     DateTime
  category        String
  priority        String      @default("MEDIUM") // LOW, MEDIUM, HIGH
  status          String      @default("ACTIVE") // ACTIVE, COMPLETED, PAUSED, CANCELLED
  auto_contribute Boolean     @default(false)
  contribution_amount Decimal? @db.Decimal(15,2)
  contribution_frequency String? // monthly, weekly, daily
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  
  // Relacionamentos
  user            User        @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("goals")
}

model Budget {
  id              String      @id @default(cuid())
  user_id         String
  category_id     String?
  name            String
  amount          Decimal     @db.Decimal(15,2)
  spent           Decimal     @default(0) @db.Decimal(15,2)
  period          String      // monthly, weekly, yearly
  start_date      DateTime
  end_date        DateTime
  alert_threshold Decimal?    @db.Decimal(5,2) // Porcentagem para alerta
  is_active       Boolean     @default(true)
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  
  // Relacionamentos
  user            User        @relation(fields: [user_id], references: [id], onDelete: Cascade)
  category        Category?   @relation(fields: [category_id], references: [id])

  @@map("budgets")
}

// ============================================================================
// TRAVEL SYSTEM - Sistema de Viagens
// ============================================================================

model Trip {
  id              String      @id @default(cuid())
  user_id         String
  name            String
  destination     String
  start_date      DateTime
  end_date        DateTime
  budget          Decimal     @db.Decimal(15,2)
  spent           Decimal     @default(0) @db.Decimal(15,2)
  currency        String      @default("BRL")
  description     String?
  status          String      @default("planning") // planning, active, completed, cancelled
  participants    String[]    @default([])
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  
  // Relacionamentos
  user            User        @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("trips")
}

// ============================================================================
// AUTOMATION & RECURRING - Automação e Recorrência
// ============================================================================

model RecurringRule {
  id              String      @id @default(cuid())
  user_id         String
  account_id      String
  category_id     String
  name            String
  description     String?
  amount          Decimal     @db.Decimal(15,2)
  type            String      // income, expense
  frequency       String      // daily, weekly, monthly, yearly
  interval        Int         @default(1)
  day_of_month    Int?        // Para frequência mensal
  day_of_week     Int?        // Para frequência semanal
  start_date      DateTime
  end_date        DateTime?
  last_executed   DateTime?
  next_execution  DateTime
  is_active       Boolean     @default(true)
  auto_execute    Boolean     @default(false)
  tags            String[]    @default([])
  metadata        Json?
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  
  // Relacionamentos
  user            User        @relation(fields: [user_id], references: [id], onDelete: Cascade)
  account         Account     @relation(fields: [account_id], references: [id], onDelete: Cascade)
  category        Category    @relation(fields: [category_id], references: [id])

  @@map("recurring_rules")
}

// ============================================================================
// AUXILIARY MODELS - Modelos Auxiliares
// ============================================================================

model Contact {
  id              String      @id @default(cuid())
  user_id         String
  name            String
  email           String?
  phone           String?
  category        String?
  notes           String?
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  
  // Relacionamentos
  user            User        @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("contacts")
}

model AuditEvent {
  id              String      @id @default(cuid())
  user_id         String?
  entity_type     String
  entity_id       String
  action          String      // CREATE, UPDATE, DELETE
  old_values      Json?
  new_values      Json?
  ip_address      String?
  user_agent      String?
  session_id      String?
  severity        String      @default("info") // info, warning, error
  tags            String[]    @default([])
  metadata        Json?
  createdAt       DateTime    @default(now()) @map("created_at")
  
  // Relacionamentos
  user            User?       @relation(fields: [user_id], references: [id])

  @@index([entity_type, entity_id])
  @@index([user_id, createdAt])
  @@index([action, createdAt])
  @@map("audit_events")
}

// ============================================================================
// VIEWS MATERIALIZADAS (Para Performance)
// ============================================================================

// Estas serão criadas via SQL direto após a migração
// VIEW account_balances - Saldos atualizados em tempo real
// VIEW monthly_summaries - Resumos mensais pré-calculados
// VIEW investment_portfolio - Portfolio consolidado
// VIEW goal_progress - Progresso das metas em tempo real