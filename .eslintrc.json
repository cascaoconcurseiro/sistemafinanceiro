{
  "extends": [
    "next/core-web-vitals"
  ],
  "rules": {
    "react-hooks/exhaustive-deps": "off",
    "react-hooks/rules-of-hooks": "warn",
    "react/no-unescaped-entities": "off",
    "react/jsx-no-undef": "off",
    "react/display-name": "off",
    "no-console": "off",
    "prefer-const": "off",
    "no-var": "error",
    "@next/next/no-assign-module-variable": "off"
  }
}