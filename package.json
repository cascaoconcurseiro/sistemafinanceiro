{
  "name": "suagrana-clean",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "build": "next build",
    "build:analyze": "ANALYZE=true next build",
    "build:prod": "NODE_ENV=production next build",
    "build:check": "tsc --noEmit && next build",
    "prebuild": "prisma generate",
    "start": "next start",
    "lint": "next lint",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "tsx prisma/seed-admin.ts",
    "security:audit": "npm audit --audit-level moderate",
    "security:test": "tsx scripts/test-security.ts",
    "setup": "tsx scripts/setup-system.ts",
    "setup:complete": "tsx scripts/setup-complete.ts",
    "migrate:database": "tsx scripts/migrate-database.ts",
    "system:validate": "tsx scripts/validate-system.ts",
    "db:optimize": "tsx scripts/optimize-database.ts",
    "audit": "tsx src/audit/run-audit.ts",
    "audit:full": "tsx src/audit/run-audit.ts --include-stress-tests",
    "audit:security": "tsx src/audit/run-audit.ts --security-only",
    "audit:quality": "tsx src/audit/run-audit.ts --quality-only",
    "backup": "node scripts/backup-database.js",
    "backup:auto": "node scripts/backup-database.js && echo Backup concluído",
    "logs:clean": "node -e \"require('fs').rmSync('logs', {recursive: true, force: true})\"",
    "logs:view": "tail -f logs/app-$(date +%Y-%m-%d).log",
    "code:clean": "node scripts/remove-all-console-logs.js",
    "code:analyze": "node scripts/analyze-code-quality.js",
    "code:jsdoc": "node scripts/add-jsdoc-comments.js",
    "code:format": "prettier --write \"src/**/*.{ts,tsx,js,jsx}\"",
    "code:format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx}\"",
    "code:quality": "npm run code:analyze && npm run lint",
    "code:unused-imports": "node scripts/remove-unused-imports.js",
    "code:duplication": "node scripts/detect-code-duplication.js",
    "code:report": "node scripts/generate-quality-report.js",
    "code:optimize-imports": "node scripts/optimize-imports.js",
    "code:fix-issues": "node scripts/fix-common-issues.js",
    "code:stats": "node scripts/generate-project-stats.js",
    "code:all": "npm run code:analyze && npm run code:unused-imports && npm run code:duplication"
  },
  "dependencies": {
    "@ducanh2912/next-pwa": "^10.2.9",
    "@hookform/resolvers": "^5.2.2",
    "@prisma/client": "^5.7.1",
    "@radix-ui/react-alert-dialog": "^1.0.5",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.1.5",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-query": "^5.90.2",
    "@tanstack/react-query-devtools": "^5.90.2",
    "@types/bcrypt": "^6.0.0",
    "@types/cron": "^2.0.1",
    "@types/crypto-js": "^4.2.2",
    "@types/pg": "^8.15.5",
    "@types/uuid": "^10.0.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "cmdk": "^1.1.1",
    "critters": "^0.0.23",
    "cron": "^4.3.3",
    "crypto-js": "^4.2.0",
    "date-fns": "^3.0.6",
    "decimal.js": "^10.6.0",
    "exceljs": "^4.4.0",
    "framer-motion": "^12.23.22",
    "html2canvas": "^1.4.1",
    "isomorphic-dompurify": "^2.29.0",
    "jsonwebtoken": "^9.0.2",
    "jspdf": "^3.0.3",
    "jspdf-autotable": "^5.0.2",
    "lru-cache": "^11.2.2",
    "lucide-react": "^0.303.0",
    "next": "^14.2.33",
    "next-auth": "^4.24.11",
    "node-cron": "^4.2.1",
    "node-fetch": "^2.7.0",
    "pg": "^8.16.3",
    "react": "^18",
    "react-day-picker": "^9.11.0",
    "react-dom": "^18",
    "react-error-boundary": "^6.0.0",
    "react-hook-form": "^7.48.2",
    "recharts": "^2.8.0",
    "rxjs": "^7.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.2.0",
    "tailwindcss-animate": "^1.0.7",
    "use-debounce": "^10.0.6",
    "uuid": "^13.0.0",
    "zod": "^3.25.76",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.0.0",
    "@playwright/test": "^1.40.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/dompurify": "^3.0.5",
    "@types/jest": "^29.5.8",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-devtools": "^3.6.2",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.0.1",
    "eslint": "^8",
    "eslint-config-next": "14.0.4",
    "glob": "^11.0.3",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "postcss": "^8",
    "prisma": "^5.7.1",
    "tailwindcss": "^3.3.0",
    "tsx": "^4.20.6",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
