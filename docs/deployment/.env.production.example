# 🗄️ DATABASE - PostgreSQL (Neon)
# Obtenha em: https://console.neon.tech
# IMPORTANTE: Use a "Pooled Connection" (com -pooler no host)
DATABASE_URL="postgresql://neondb_owner:SENHA@ep-xxx-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require"

# 🔒 JWT - Gere chaves únicas com:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="sua-chave-jwt-de-64-caracteres-aqui"
JWT_REFRESH_SECRET="sua-chave-refresh-de-64-caracteres-aqui"
JWT_EXPIRES_IN="24h"
JWT_REFRESH_EXPIRES_IN="7d"

# 🔐 CRON - Para jobs agendados
CRON_SECRET="sua-chave-cron-de-64-caracteres-aqui"

# 🌍 AMBIENTE
NODE_ENV="production"
NEXT_PUBLIC_APP_URL="https://seu-site.netlify.app"

# 🔒 CORS
ALLOWED_ORIGINS="https://seu-site.netlify.app"

# ⚡ RATE LIMITING
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60000

# 💾 BACKUP
BACKUP_ENABLED=true
BACKUP_RETENTION_DAYS=30

# 📝 LOGS
LOG_LEVEL="info"
LOG_RETENTION_DAYS=7

# 📧 EMAIL (Opcional - Configure depois)
# SMTP_HOST=""
# SMTP_PORT=""
# SMTP_USER=""
# SMTP_PASS=""

# 🔐 2FA (Opcional)
# TWO_FACTOR_ENABLED=false

# 📊 SENTRY (Opcional - Monitoramento)
# SENTRY_DSN=""
# NEXT_PUBLIC_SENTRY_DSN=""
