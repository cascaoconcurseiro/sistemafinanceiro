# Configurações de Produção
NODE_ENV=production
NEXT_TELEMETRY_DISABLED=1
ANALYZE=false

# Database (usar variáveis de ambiente do servidor)
# DATABASE_URL será fornecida pelo ambiente de produção

# NextAuth (usar variáveis de ambiente do servidor)
# NEXTAUTH_URL será fornecida pelo ambiente de produção
# NEXTAUTH_SECRET será fornecida pelo ambiente de produção
