# Configurações de produção para Netlify
NEXTAUTH_URL=https://seu-site.netlify.app
NEXTAUTH_SECRET=sua-chave-secreta-aqui
JWT_SECRET=sua-jwt-secret-super-segura-aqui-32-chars-min
JWT_REFRESH_SECRET=sua-jwt-refresh-secret-super-segura-aqui
DATABASE_URL=file:./dev.db

# Desabilitar funcionalidades que requerem servidor
DISABLE_API_ROUTES=true
STATIC_EXPORT=true