# Database
DATABASE_URL="file:./dev.db"

# 🔒 SEGURANÇA: JWT (OBRIGATÓRIO EM PRODUÇÃO)
# Gerar chave segura: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production-minimum-32-chars"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-this-in-production-minimum-32-chars"
JWT_EXPIRES_IN="24h"
JWT_REFRESH_EXPIRES_IN="7d"

# Cron Jobs
CRON_SECRET="your-cron-secret-key-change-this"

# Sentry (Monitoramento)
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""

# CORS
ALLOWED_ORIGINS="http://localhost:3000,https://yourdomain.com"

# Email (Futuro)
SMTP_HOST=""
SMTP_PORT=""
SMTP_USER=""
SMTP_PASS=""

# 2FA (Futuro)
TWO_FACTOR_ENABLED="false"

# Environment
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Rate Limiting
RATE_LIMIT_MAX="100"
RATE_LIMIT_WINDOW="60000"

# Backup
BACKUP_ENABLED="true"
BACKUP_RETENTION_DAYS="30"

# Logs
LOG_LEVEL="info"
LOG_RETENTION_DAYS="7"
